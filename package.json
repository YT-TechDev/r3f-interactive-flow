{
  "name": "r3f-interactive-flow-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm --filter r3f-interactive-flow build",
    "typecheck": "pnpm --filter r3f-interactive-flow typecheck",
    "test": "pnpm --filter r3f-interactive-flow test",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:check": "pnpm build && pnpm typecheck && pnpm test && pnpm lint && pnpm format && pnpm --filter vite-basic build && pnpm pack:dry-run",
    "release": "pnpm release:check && changeset publish",
    "pack:dry-run": "pnpm --filter r3f-interactive-flow pack:dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@react-three/fiber": "^9.6.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
