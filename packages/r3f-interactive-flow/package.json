{
  "name": "r3f-interactive-flow",
  "version": "0.2.0",
  "description": "A small React Three Fiber utility for predictable phase-based interactive flow control.",
  "license": "MIT",
  "author": "YT-TechDev",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "react-three-fiber",
    "three",
    "react",
    "r3f",
    "interactive",
    "phase",
    "flow",
    "animation",
    "webgl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YT-TechDev/r3f-interactive-flow.git",
    "directory": "packages/r3f-interactive-flow"
  },
  "homepage": "https://github.com/YT-TechDev/r3f-interactive-flow#readme",
  "bugs": {
    "url": "https://github.com/YT-TechDev/r3f-interactive-flow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dry-run": "pnpm build && npm pack --dry-run"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8.0.0 <10.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0",
    "three": ">=0.150.0 <1.0.0"
  },
  "devDependencies": {}
}
